    "auth": {
      "methods": [
        "none"
      ],
      "jwtSecret": "not-used",
      "credentials": [
        {
          "email": "admin",
          "password": "admin123",
          "role": "admin"
        }
      ],
      "apiKeys": {}
    },
    "requestSchema": {
      "messageField": "message",
      "roleField": "role",
      "apiKeyField": "api_key",
      "guardrailModeField": "guardrail_mode"
    },
    "responseSchema": {
