        "headers": {
          "Content-Type": "application/json"
        },
        "bodyTemplate": "{\"message\": \"{{message}}\", \"user_id\": 1}",
        "responsePath": "assistant"
      }
    },
    "codebasePath": "/home/sam/Downloads/vuln-ai-redteam-lab",
