{
  "target": {
    "type": "http_agent",
    "baseUrl": "http://localhost:8000",
    "agentEndpoint": "/process/conversation",
    "applicationDetails": "Insurance customer assistant chatbot. Handles policy inquiries, claims, billing.",
    "preAuthCommand": {
      "command": "python3 scripts/get_esso_token_mock.py 9245099016",
      "outputVar": "E_SSO_TOKEN"
    },
    "setupSteps": [
      {
        "name": "Create conversation",
        "url": "/start/conversation",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "X-Service-Key": "test-service-key",
          "e-sso-token": "{{var:E_SSO_TOKEN}}"
        },
        "body": {
          "conversationId": "{{uuid}}",
          "policyNumber": "9245099016",
          "firstName": "Road",
          "lastName": "Runner",
          "email": "acme@acme.com",
          "applicationId": "{{uuid}}",
          "lob": "Auto",
          "state": "CA",
          "clientId": "{{uuid}}",
          "userRole": "test",
          "geicoId": "test"
        },
        "extract": {
          "conversationId": "conversationId"
        }
      }
    ],
    "refreshPerRound": true,
    "refreshPerConversation": true,
    "customApiTemplate": {
      "method": "POST",
      "headers": {
        "Content-Type": "application/json",
        "X-Service-Key": "test-service-key",
        "e-sso-token": "{{var:E_SSO_TOKEN}}"
      },
      "bodyTemplate": "{\"conversationId\": \"{{var:conversationId}}\", \"requestId\": \"{{uuid}}\", \"schemaVersion\": \"1.0.0\", \"calling_app_id\": \"customer_assistant_v2.0\", \"inputType\": \"query\", \"quickLink\": \"\", \"message\": {\"messageId\": \"{{uuid}}\", \"direction\": \"inbound\", \"producer\": \"customer\", \"parts\": [{\"partKind\": \"text\", \"textMarkdown\": \"{{message}}\"}]}}",
      "responsePath": "messages[0].parts[0].textMarkdown"
    }
  },
  "codebasePath": null,
  "codebaseGlob": "**/*.{ts,js,py}",
  "auth": {
    "methods": ["none"],
    "jwtSecret": "",
    "credentials": [],
    "apiKeys": {}
  },
  "responseSchema": {
    "responsePath": "messages[0].parts[0].textMarkdown",
    "toolCallsPath": "tool_calls",
    "userInfoPath": "user",
    "guardrailsPath": "guardrails"
  },
  "sensitivePatterns": [
    "policy_number", "POL-", "SSN", "\\d{3}-\\d{2}-\\d{4}",
    "password", "secret", "api[_-]?key", "token"
  ],
  "attackConfig": {
    "adaptiveRounds": 1,
    "attacksPerCategory": 3,
    "enableLlmGeneration": false,
    "llmProvider": "custom",
    "llmModel": "AISolutions6GVASAAPTUs",
    "judgeProvider": "custom",
    "judgeModel": "AISolutions6GVASAAPTUs",
    "requireReviewConfirmation": false,
    "enabledCategories": [
      "prompt_injection",
      "pii_disclosure"
    ]
  }
}
